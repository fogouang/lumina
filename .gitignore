backend/.eggs/

# Testing
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/

# UV (Package Manager)
backend/.uv/

# Environment variables
backend/.env
backend/.env.local
backend/.env.*.local

# Logs
backend/logs/
backend/**/*.log

# Database files
backend/**/*.sqlite
backend/**/*.sqlite3
backend/**/*.db
backend/alembic/versions/

# Uploads
backend/uploads/
backend/media/

# Temporary files
backend/tmp/
backend/temp/
