# Backup files
backend/**/*.bak
backend/**/*.backup
backend/**/*.old

# Secrets
backend/secrets/
backend/.secrets/
backend/**/*.secret
backend/**/*.pem
backend/**/*.key
backend/**/*.crt

backend/storage/uploads/images
backend/storage/uploads/audio
