backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class
backend/**/*.so

# Virtual environments
backend/.venv/
backend/venv/
backend/env/
backend/ENV/

# Python distribution
backend/build/
backend/dist/
